<Window x:Class="VoicemeeterDelay.VbanCommandsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VBAN Commands"
        Width="820"
        Height="760"
        MinWidth="620"
        MinHeight="520"
        Background="{StaticResource FieldBrush}"
        FontFamily="Segoe UI"
        FontSize="14"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0"
               Text="VBAN Text Command Reference"
               FontSize="20"
               FontWeight="SemiBold"
               Margin="0,0,0,12" />

    <Border Grid.Row="1"
            Background="{StaticResource PanelBrush}"
            BorderBrush="{StaticResource StrokeBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">
      <TextBox x:Name="CommandsTextBox"
               Background="{StaticResource PanelBrush}"
               Foreground="{StaticResource TextBrush}"
               BorderThickness="0"
               FontFamily="Consolas"
               FontSize="13"
               IsReadOnly="True"
               TextWrapping="Wrap"
               HorizontalScrollBarVisibility="Auto"
               VerticalScrollBarVisibility="Auto" />
    </Border>

    <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Content="Copy"
              Width="90"
              ToolTip="Copy the full VBAN command reference to the clipboard."
              Click="CopyButton_Click" />
      <Button Content="Close"
              Width="90"
              Margin="10,0,0,0"
              ToolTip="Close this reference window."
              Click="CloseButton_Click" />
    </StackPanel>
  </Grid>
</Window>
